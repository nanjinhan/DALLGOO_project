# ===== MySQL (컨테이너 초기화용) =====
MYSQL_ROOT_PASSWORD=change_this_root_pw
MYSQL_DATABASE=dallgoo_board
MYSQL_USER=dallgoo
MYSQL_PASSWORD=change_this_pw

# ===== 백엔드 DB 접속 =====
# 도커 네트워크 내부에서 호스트는 컨테이너명 'db'
DATABASE_URL=mysql+pymysql://dallgoo:change_this_pw@db:3306/dallgoo_board

# ===== JWT =====
# 길고 무작위한 값으로 교체 (예: python -c "import secrets;print(secrets.token_urlsafe(64))")
JWT_SECRET_KEY=replace_with_a_long_random_secret
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=14

# ===== CORS (프론트 dev 서버) =====
CORS_ORIGINS=http://localhost:5173

# ===== 파일 업로드 =====
UPLOAD_DIR=/app/uploads
MAX_UPLOAD_SIZE_MB=10

# ===== Redis (도커 네트워크 내부 호스트는 'redis') =====
REDIS_URL=redis://redis:6379/0

# ===== 이메일 발송 (Gmail SMTP) =====
# 비워두면 '메일 발송 대신 서버 로그' 모드. 실제 발송하려면 Gmail 앱 비밀번호 입력.
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=달구 게시판 <no-reply@dallgoo.io>
